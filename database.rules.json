{
  "rules": {
    "favorites": {
      ".read": true,
      "$prayer": {
        "$photo": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999"
        }
      }
    },
    "blocked": {
      ".read": true,
      "$prayer": {
        "$photo": {
          ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
          "notes": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1000)"
          }
        }
      }
    },
    "blockedKeywords": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
      "$index": {
        ".validate": "newData.isString() && newData.val().length <= 200"
      }
    },
    "searchTerms": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
      "$prayer": {
        ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)"
      }
    },
    "reports": {
      ".read": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
      "$prayer": {
        "$photo": {
          ".write": true,
          "notes": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1000)"
          }
        }
      }
    },
    "customPrayers": {
      ".read": true,
      "$id": {
        ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
        "name": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
        },
        "label": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
        }
      }
    },
    "hiddenPrayers": {
      ".read": true,
      "$id": {
        ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
        ".validate": "newData.isBoolean()"
      }
    },
    "prayerDisplayNames": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
      "$id": {
        ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
      }
    },
    "prayerOrder": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'"
    },
    "prayerTags": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
      "$id": {
        ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 50)"
      }
    },
    "pendingPrayers": {
      ".read": true,
      "$id": {
        ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42' || (!data.exists() && newData.child('status').val() === 'pending')",
        "name": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
        },
        "label": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
        },
        "status": {
          ".validate": "!newData.exists() || newData.val() === 'pending' || newData.val() === 'approved' || newData.val() === 'dismissed'"
        }
      }
    },
    "siteDefaults": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'"
    },
    "promotedPrayers": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'"
    },
    "filters": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'"
    },
    "prayerThemes": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
      "$id": {
        ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)"
      }
    },
    "pinnedPhotos": {
      ".read": true,
      "$prayer": {
        ".write": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'"
      }
    },
    "suggestions": {
      ".read": "auth != null && auth.uid === 'tizvHyzJ7PdsPvFpbEk4CdSPUk42'",
      "$prayer": {
        "$photo": {
          ".write": true,
          "notes": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1000)"
          }
        }
      }
    },
    "binahVotes": {
      ".read": false,
      "$id": {
        ".write": "!data.exists()",
        ".validate": "newData.child('t').val() === root.child('binahConfig/token').val() && newData.child('link').isString() && newData.child('link').val().length <= 500 && newData.child('title').isString() && newData.child('title').val().length <= 300 && newData.child('source').isString() && newData.child('source').val().length <= 100 && (newData.child('vote').val() === 'up' || newData.child('vote').val() === 'down') && newData.child('ts').isNumber() && (!newData.child('reason').exists() || (newData.child('reason').isString() && newData.child('reason').val().length <= 500))"
      }
    },
    "binahConfig": {
      ".read": false,
      ".write": false
    }
  }
}
